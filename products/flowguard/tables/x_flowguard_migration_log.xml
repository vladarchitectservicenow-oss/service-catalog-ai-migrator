<?xml version="1.0" encoding="UTF-8"?>
<database>
    <element label="FlowGuard Migration Log" max_length="40" name="x_flowguard_migration_log" type="collection" extends="sys_audit">
        <element label="Migration ID" max_length="64" name="migration_id" type="string" mandatory="true" unique="true" read_only="true"/>
        <element label="Source Flow" name="source_flow_id" type="reference" reference="sys_hub_flow" mandatory="true"/>
        <element label="Target Flow" name="target_flow_id" type="reference" reference="sys_hub_flow"/>
        <element label="Status" max_length="40" name="status" type="choice" mandatory="true" choice="1" default="in_progress">
            <choice>
                <element label="In Progress" value="in_progress"/>
                <element label="Success" value="success"/>
                <element label="Validation Failed" value="validation_failed"/>
                <element label="Verify Failed" value="verify_failed"/>
                <element label="Rolled Back" value="rolled_back"/>
                <element label="Error" value="error"/>
            </choice>
        </element>
        <element label="Action" max_length="40" name="action" type="choice">
            <choice>
                <element label="Created" value="created"/>
                <element label="Updated" value="updated"/>
            </choice>
        </element>
        <element label="Snapshot" name="snapshot_id" type="reference" reference="x_flowguard_snapshot"/>
        <element label="Issues" max_length="8000" name="issues" type="string"/>
        <element label="Requested By" name="requested_by" type="reference" reference="sys_user"/>
        <element label="Started At" name="started_at" type="glide_date_time" read_only="true"/>
        <element label="Completed At" name="completed_at" type="glide_date_time" read_only="true"/>
    </element>
</database>
